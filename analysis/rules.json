          "content moderation", "filter", "guardrail",
          "privacy", "leakage", "memorization", "data contamination",
          "fairness", "bias", "discrimination",
          "hallucination detection", "truthfulness", "factuality",
          "interpretability", "explainability", "transparency",
          "trustworthiness", "reliability", "risk",
          "societal impact", "ethical", "governance",
          "autonomous", "agent safety", "tool safety"
        ]
      },
      "model_context": true
    },
    {
      "level": 2,
      "name": "大模型内生能力研究",
      "description": "探索模型的各方面能力（推理、规划、知识、工具使用等）",
