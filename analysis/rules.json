{
  "version": "1.1",
  "description": "大模型论文相关性分析规则 - 四等级分类系统（仅使用标题分析）",
  "definition": {
    "large_models": [
      "LLM", "RLLM", "MLLM", "DLLM", "MoE", "Agent",
      "language model", "multimodal model", "large model",
      "foundation model", "transformer", "GPT", "BERT",
      "reasoning model", "diffusion model", "mixture of experts",
