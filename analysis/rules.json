      "alignment", "hallucination", "interpretability",
      "safety", "robustness", "fairness", "privacy",
      "jailbreak", "adversarial attack", "poisoning",
      "backdoor", "data contamination", "benchmark",
      "evaluation", "capability", "reasoning", "planning",
      "tool use", "code generation", "math reasoning",
      "knowledge", "memory", "generalization",
      "scaling law", "emergence", "capability emergence"
